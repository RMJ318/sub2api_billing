{
  "name": "ai-usage-analytics",
  "version": "0.1.0",
  "private": true,
  "description": "AI Usage Analytics Platform - enterprise-internal dashboard over sub2api billing CSV exports",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/compute",
    "packages/ingest",
    "packages/store",
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:web": "npm run build --workspace @app/web",
    "check:web": "npm run build:web",
    "clean": "tsc -b --clean && rimraf --glob packages/*/dist packages/web/dist",
    "rebuild:web": "npm run clean && npm run build:web",
    "typecheck": "tsc -b && npm run typecheck --workspace @app/web",
    "typecheck:web": "npm run typecheck --workspace @app/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:api": "npm run dev --workspace @app/api",
    "dev:web": "npm run dev --workspace @app/web"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "rimraf": "6.1.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.8"
  }
}
